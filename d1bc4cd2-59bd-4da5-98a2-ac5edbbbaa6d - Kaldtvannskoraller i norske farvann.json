  "characters": [
    {
      "id": "character:1781698348404551ae66cc42fe901b76",
      "title": {
        "nb": "Vekstform og tilhefting"
      },
      "states": [
        {
          "id": "state:dc43881c04944ad6a65501306dba89af",
          "title": {
            "nb": "Organismen er festet til hardbunn med base eller rot. Koloni oppreist, greinaktig, buskformet, vifteformet eller massiv revstruktur."
          }
        },
        {
          "id": "state:6084a9b6c18049009900846829bce856",
          "title": {
            "nb": "Organismen står i bløtbunn (mudder/sand), festet med en underjordisk pedunkel (stilk). Fjær- eller klubbeformet, med sentral akse og laterale polypper."
          }
        }
      ]
    },
    {
      "id": "character:ceadc9631fc04998af3e616583cd8349",
      "title": {
        "nb": "Skjelettstruktur: kalk eller organisk?"
      },
      "states": [
        {
          "id": "state:fcf833d0e1344acf862ae23daeb182d1",
          "title": {
            "nb": "Kolonien har hard, rigid kalkstruktur (CaCO₃). Skjelettet er stivt og skjørt. Polyppene sitter i tydelige kalkkopper (corallitter)."
          }
        },
        {
          "id": "state:3a25ac72ebf04c9e854fb30f451482db",
          "title": {
            "nb": "Kolonien har fleksibelt eller blandingsskjelett. Kan være gorgonin-basert, leddelt (bambus), eller kjøttfullt uten rigid skjelett."
          }
        }
      ]
    },
    {
      "id": "character:c7a9fc7254704184a89bfc208931dbe0",
      "title": {
        "nb": "Steinkoraller (Scleractinia)"
      },
      "states": [
        {
          "id": "state:3a88b3e6f2dd483985d08083e6d90f97",
          "title": {
            "nb": "Store, massive revstrukturer. Greiner tett forgrenede, avrundede. Corallitter sir-kulære, Ø 10–15 mm. Farge hvit eller oransje."
          }
        },
        {
          "id": "state:87eed351f8554f8b95b00fc6b5d2a287",
          "title": {
            "nb": "Slankere kolonistruktur med tydelig sikksakkformet greinmønster. Corallitter mindre, Ø 3–5 mm. Mer åpen og delikat."
          }
        }
      ]
    },
    {
      "id": "character:98fccddcc523435c876315e47c312384",
      "title": {
        "nb": "Fleksible koraller: bløtkorall, hornkorall eller bambuskorall?"
      },
      "states": [
        {
          "id": "state:4259444677a64862ab1c61f47688570f",
          "title": {
            "nb": "Kolonien er kjøttfull, kompakt, sopp- eller pute-formet, uten tydelige greiner. Overflaten glatt eller lobat."
          }
        },
        {
          "id": "state:b1eda60397f849598e0e3d6e4bdc485c",
          "title": {
            "nb": "Kolonien er oppreist med tydelige greiner, vifteform eller buskform. Skjelett fleksibelt eller leddelt."
          }
        }
      ]
    },
    {
      "id": "character:9e5cdbf625d941bbb3e0f1624e2c1d86",
      "title": {
        "nb": "Skjeletttype: leddelt eller sammenhengende?"
      },
      "states": [
        {
          "id": "state:41466192b52f4d979b1e5d77fe7e2fab",
          "title": {
            "nb": "Skjelettet er tydelig leddelt (segmentert), med vekslende hornledd og kalkledd som gir en bambuslignende struktur."
          }
        },
        {
          "id": "state:184d27ecdbff4851b4a97c259e3ae057",
          "title": {
            "nb": "Skjelettet sammenhengende, fleksibelt, gorgonin-basert. Greiner bøyer seg i strøm."
          }
        }
      ]
    },
    {
      "id": "character:85cc021d80cb47c8b1f13cbf0980b3a8",
      "title": {
        "nb": "Hornkoraller (Gorgonacea s.l.)"
      },
      "states": [
        {
          "id": "state:7ca2c4e2a07a46e1ac08a7be54ebeafb",
          "title": {
            "nb": "Kraftig tre-/buskformet koloni med tykk hovedstamme og robuste sidegreiner. Ofte >1 m. Vev tykt, kjøttfullt. Rødlig/rosa."
          }
        },
        {
          "id": "state:9bdecaa6f3cf4f8591360d72f984fbd4",
          "title": {
            "nb": "Kompakt buskform med knoppet/granulert overflate («risengryns»-tekstur). Farge hvit, gul eller lys rosa. Tredimensjonal forgreining."
          }
        },
        {
          "id": "state:4cc8515c3efa4a97b279667812d3ff22",
          "title": {
            "nb": "Koloni vifteformet, greiner i étt plan (todimensjonal). Overflate jevnere. Oransje, rødlig eller brun. Orientert mot strøm."
          }
        },
        {
          "id": "state:5db438e7b5b3475f83f3e4d358c4959b",
          "title": {
            "nb": "Liten, spinkel koloni (<20 cm). Uregelmessig forgreining. Polyppene store i forhold til greindiameter. Hvitlig eller transparent."
          }
        },
        {
          "id": "state:53a526387e95478aa50c7597dae28528",
          "title": {
            "nb": "Svært liten, slank koloni (<15 cm). Spinkle, glatte greiner. Farge blek hvit, gul eller rosa. Fåtallige polypper."
          }
        }
      ]
    },
    {
      "id": "character:1c5fc499d1e745d183b3a000f428d67a",
      "title": {
        "nb": "Bambuskoraller (Isididae)"
      },
      "states": [
        {
          "id": "state:935ebdbb0bcd4b2b83b950752c0b8196",
          "title": {
            "nb": "Koloni oppreist, kandelaber- eller vifteformet. Greiner i ett plan eller spredt. Bløtbunn. Vanlig i fjorder 200–500 m."
          }
        },
        {
          "id": "state:f1b63c5d59cd4a62823729c094aa7b83",
          "title": {
            "nb": "Koloni svært slank, enkel eller sparsomt forgreinet. Lang, tynn stilk. Dypvann >500 m. Kun Nord-Norge."
          }
        }
      ]
    },
    {
      "id": "character:8bf8e0ebb3194e6e9104756f0f28f3c8",
      "title": {
        "nb": "Bløtkoraller (Alcyoniidae)"
      },
      "states": [
        {
          "id": "state:b7d3627118934f4ab8543fdc8bb44b95",
          "title": {
            "nb": "Koloni sopp- eller klokkeformet, massiv, kjøttfull. Store polypper (autozoider) tydelig synlige på overflaten. Rød eller rosa. >300 m."
          }
        },
        {
          "id": "state:b842f56edd4f491c8d163fb21be5da20",
          "title": {
            "nb": "Koloni lavtvoksende, myk, med korte lober eller fingerformede utløpere. Polypper små, jevnt fordelt. Hvitlig. Grunnere."
          }
        }
      ]
    },
    {
      "id": "character:8ddef72fd1b7459ea5e0c83bec407f87",
      "title": {
        "nb": "Sjøfjær (Pennatulacea)"
      },
      "states": [
        {
          "id": "state:9235b01b00fa47589e3e41f2a72f3a01",
          "title": {
            "nb": "Kolonien lang, slank, piperenserlignende. Polypper sitter direkte på en lang, firkant-akse. Ofte >50 cm. Bløtbunn >100 m."
          }
        },
        {
          "id": "state:3b1b5e41117e46088bfe064fee4698c6",
          "title": {
            "nb": "Kolonien har en annen form enn piperenser."
          }
        }
      ]
    },
    {
      "id": "character:45a3fbd1d40e45eeb07b695a02f06bc9",
      "title": {
        "nb": "11"
      },
      "states": [
        {
          "id": "state:666e0e2d62d2400a8df4d87e5ff7079d",
          "title": {
            "nb": "Kolonien kort, klubbeformet med oppsvulmet distal ende. Polypper sitter på en kompakt topp. Gulhvit. 100–700 m."
          }
        },
        {
          "id": "state:0a34dc1f636e4dbaa1673ca9e54ff12b",
          "title": {
            "nb": "Kolonien fjærformet med tydelige sideblader (polyppblader) langs sentral akse."
          }
        }
      ]
    },
    {
      "id": "character:3cf8848dacd449b499f1a4de39c21c3c",
      "title": {
        "nb": "12"
      },
      "states": [
        {
          "id": "state:d2ec11ec7c034e58b86e123bbaa3514e",
          "title": {
            "nb": "Sideblader store, brede, kjøttfulle. Koloni robust, ofte rødoransje. Myk sentral akse. <100 m i gruntområder, ellers dypere."
          }
        },
        {
          "id": "state:735ade9ccdbf49049cfd1aaf0442e912",
          "title": {
            "nb": "Sideblader små eller kolonien svært slank."
          }
        }
      ]
    },
    {
      "id": "character:324bfe13ed66493faee5b29a6226f6a4",
      "title": {
        "nb": "13"
      },
      "states": [
        {
          "id": "state:97051f8c15ee46dead8cb869fd4771d9",
          "title": {
            "nb": "Koloni svært slank, nåleformet. Kan trekke seg ned i sedimentet. Små polypper langs hele aksen. 10–400 m. Vanligste sjøfjær."
          }
        },
        {
          "id": "state:399db3a1f43d4466887865e51d73f427",
          "title": {
            "nb": "Koloni slank men med mer tydelige sidestrukturer. Dypvann >200 m. Sjelden. Primært Nord-Norge."
          }
        }
      ]
    }
  ],
